/**
 * core/model.js
 * Builds, trains, and manages the TensorFlow.js neural network
 */

export class NeuralModel {
  constructor() {
    this.model = null;
    this.lossHistory = [];
    this.accHistory = [];
    this.isTraining = false;
  }

  buildModel(layerDefs) {
    if (this.model) {
      this.model.dispose();
      this.model = null;
    }

    const model = tf.sequential();
    let isFirst = true;

    for (const def of layerDefs) {
      if (def.type === 'dense') {
        const cfg = {
          units: def.units,
          activation: def.activation || 'relu',
        };
        if (isFirst) { cfg.inputShape = [2]; isFirst = false; }
        model.add(tf.layers.dense(cfg));
      } else if (def.type === 'dropout') {
        if (isFirst) {
          model.add(tf.layers.dense({ units: 8, activation: 'relu', inputShape: [2] }));
          isFirst = false;
        }
        model.add(tf.layers.dropout({ rate: def.rate || 0.3 }));
      } else if (def.type === 'activation') {
        if (isFirst) {
          model.add(tf.layers.dense({ units: 8, inputShape: [2] }));
          isFirst = false;
        }
        model.add(tf.layers.activation({ activation: def.activation || 'relu' }));
      }
    }

    // Ensure output layer
    if (isFirst) {
      model.add(tf.layers.dense({ units: 8, activation: 'relu', inputShape: [2] }));
    }
    model.add(tf.layers.dense({ units: 1, activation: 'sigmoid' }));

    this.model = model;
    return model;
  }

  compile(optimizerName = 'adam', learningRate = 0.01) {
    if (!this.model) return;
    let optimizer;
    if (optimizerName === 'adam') optimizer = tf.train.adam(learningRate);
    else if (optimizerName === 'sgd') optimizer = tf.train.sgd(learningRate);
    else if (optimizerName === 'rmsprop') optimizer = tf.train.rmsprop(learningRate);
    else optimizer = tf.train.adam(learningRate);

    this.model.compile({
      optimizer,
      loss: 'binaryCrossentropy',
      metrics: ['accuracy'],
    });
  }

  async train({ X, y, epochs, batchSize, onEpochEnd, onBatchEnd }) {
    if (!this.model) return;
    this.isTraining = true;
    this.lossHistory = [];
    this.accHistory = [];

    const xs = tf.tensor2d(X);
    const ys = tf.tensor2d(y, [y.length, 1]);

    await this.model.fit(xs, ys, {
      epochs,
      batchSize,
      shuffle: true,
      callbacks: {
        onEpochEnd: (epoch, logs) => {
          this.lossHistory.push(logs.loss);
          this.accHistory.push(logs.acc ?? logs.accuracy ?? 0);
          if (onEpochEnd) onEpochEnd(epoch, logs, this.lossHistory, this.accHistory);
        },
        onBatchEnd: (batch, logs) => {
          if (onBatchEnd) onBatchEnd(batch, logs);
        },
        onTrainEnd: () => { this.isTraining = false; },
      },
    });

    xs.dispose();
    ys.dispose();
  }

  stopTraining() {
    if (this.model && this.isTraining) {
      this.model.stopTraining = true;
      this.isTraining = false;
    }
  }

  predict(x1, x2) {
    if (!this.model) return null;
    return tf.tidy(() => {
      const input = tf.tensor2d([[x1, x2]]);
      const out = this.model.predict(input);
      return out.dataSync()[0];
    });
  }

  // Returns a 2D grid of predictions for boundary rendering
  predictGrid(resolution = 60, xRange = [-1.5, 1.5], yRange = [-1.5, 1.5]) {
    if (!this.model) return null;
    return tf.tidy(() => {
      const points = [];
      for (let row = 0; row < resolution; row++) {
        for (let col = 0; col < resolution; col++) {
          const x1 = xRange[0] + (col / (resolution - 1)) * (xRange[1] - xRange[0]);
          const x2 = yRange[0] + (row / (resolution - 1)) * (yRange[1] - yRange[0]);
          points.push([x1, x2]);
        }
      }
      const inputTensor = tf.tensor2d(points);
      const preds = this.model.predict(inputTensor);
      return Array.from(preds.dataSync());
    });
  }

  countParams() {
    if (!this.model) return 0;
    return this.model.countParams();
  }

  async saveToIndexedDB(name = 'neural-playground-model') {
    if (!this.model) return;
    await this.model.save(`indexeddb://${name}`);
  }

  async loadFromIndexedDB(name = 'neural-playground-model') {
    try {
      this.model = await tf.loadLayersModel(`indexeddb://${name}`);
      this.compile();
      return true;
    } catch {
      return false;
    }
  }

  async exportJSON() {
    if (!this.model) return null;
    const weights = this.model.getWeights().map(w => ({
      name: w.name,
      shape: w.shape,
      data: Array.from(w.dataSync()),
    }));
    return JSON.stringify({ architecture: this.model.toJSON(), weights }, null, 2);
  }
}
